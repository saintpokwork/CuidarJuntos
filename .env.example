# Variáveis de ambiente necessárias para produção/local cloud mode.
# Não adicionar chaves reais neste ficheiro.

REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=
REACT_APP_PUBLIC_SITE_URL=https://www.cuidarjuntos.pt

# Vite também aceita variáveis VITE_*. Mantemos REACT_APP_* para evitar
# renomear os valores já configurados na Vercel.

# Usado apenas no servidor Vercel para envio de convites familiares.
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@cuidarjuntos.pt

# Stripe — price IDs are public frontend config. Secret keys are server-only.
REACT_APP_STRIPE_PUBLISHABLE_KEY=
REACT_APP_STRIPE_PRICE_FAMILY_MONTHLY=price_1TgqLoJQtTgFX7PdL3WqWpn9
REACT_APP_STRIPE_PRICE_FAMILY_YEARLY=price_1ThdIdJQtTgFX7Pdx6ZUBeaM
REACT_APP_STRIPE_PRICE_HOUSEHOLDS_MONTHLY=price_1TgqLpJQtTgFX7Pd61QfPWgF
REACT_APP_STRIPE_PRICE_HOUSEHOLDS_YEARLY=price_1ThdJ7JQtTgFX7PdmYVvh3nC
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Server-only. Required for Stripe webhook/customer portal subscription sync.
SUPABASE_SERVICE_ROLE_KEY=
