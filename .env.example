# Variáveis de ambiente necessárias para produção/local cloud mode.
# Não adicionar chaves reais neste ficheiro.

REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=
REACT_APP_PUBLIC_SITE_URL=https://www.cuidarjuntos.pt

# Vite também aceita variáveis VITE_*. Mantemos REACT_APP_* para evitar
# renomear os valores já configurados na Vercel.

# Usado apenas no servidor Vercel para envio de convites familiares.
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@cuidarjuntos.pt
